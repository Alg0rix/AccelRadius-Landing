---
import { compareAfter, compareBefore } from "../../lib/landing-content"
---

<section id="bandingkan" class="relative scroll-mt-20 overflow-hidden bg-muted/40 py-16 md:py-20">
  <div
    data-parallax="55"
    data-parallax-trigger="#bandingkan"
    class="pointer-events-none absolute -left-20 top-10 size-64 rounded-full bg-brand-blue/10 blur-3xl will-change-transform"
  >
  </div>
  <div
    data-parallax="-45"
    data-parallax-trigger="#bandingkan"
    class="pointer-events-none absolute -right-16 bottom-8 size-56 rounded-full bg-brand-red/10 blur-3xl will-change-transform"
  >
  </div>

  <div class="relative mx-auto max-w-7xl px-6">
    <div data-animate="reveal" class="mb-10 max-w-2xl">
      <p class="mb-2 text-sm font-semibold text-brand-red">Sebelum & sesudah</p>
      <h2 class="text-3xl font-bold tracking-tight md:text-4xl">
        Satu sistem menggantikan lima alat
      </h2>
      <p class="mt-3 text-muted-foreground">
        Banyak ISP menjalankan operasi dengan spreadsheet, billing terpisah, dan
        kontrol jaringan manual. Accel Radius menyatukan alur kerja itu.
      </p>
    </div>

    <div data-stagger class="grid gap-4 lg:grid-cols-2">
      <div
        data-stagger-item
        data-hover-lift
        class="rounded-2xl border border-border bg-background p-6 md:p-8"
      >
        <p class="mb-4 text-xs font-semibold uppercase tracking-wider text-muted-foreground">
          Tanpa platform terpadu
        </p>
        <ul class="space-y-3">
          {
            compareBefore.map((item) => (
              <li class="flex items-start gap-3 text-sm text-muted-foreground">
                <span class="mt-1.5 size-1.5 shrink-0 rounded-full bg-muted-foreground/50" />
                {item}
              </li>
            ))
          }
        </ul>
      </div>

      <div
        data-stagger-item
        data-hover-lift
        class="rounded-2xl border border-brand-blue/25 bg-gradient-to-br from-brand-blue/5 to-transparent p-6 md:p-8"
      >
        <p class="mb-4 text-xs font-semibold uppercase tracking-wider text-brand-blue">
          Dengan Accel Radius
        </p>
        <ul class="space-y-3">
          {
            compareAfter.map((item) => (
              <li class="flex items-start gap-3 text-sm">
                <span class="mt-0.5 flex size-5 shrink-0 items-center justify-center rounded-full bg-brand-blue/15 text-[10px] font-bold text-brand-blue">
                  ✓
                </span>
                {item}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>