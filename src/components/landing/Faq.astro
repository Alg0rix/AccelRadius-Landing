---
import { faqItems } from "../../lib/landing-content"
---

<section id="faq" class="scroll-mt-20 border-t border-border py-16 md:py-20">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mb-10 max-w-2xl">
      <p class="mb-2 text-sm font-semibold text-brand-blue">Pertanyaan umum</p>
      <h2 class="text-3xl font-bold tracking-tight md:text-4xl">FAQ</h2>
      <p class="mt-3 text-muted-foreground">
        Jawaban singkat seputar instalasi, integrasi, lisensi, dan operasional
        Accel Radius.
      </p>
    </div>

    <div class="mx-auto max-w-3xl divide-y divide-border rounded-2xl border border-border bg-background">
      {
        faqItems.map((item) => (
          <details class="group px-5 py-4 md:px-6">
            <summary class="cursor-pointer list-none text-sm font-semibold tracking-tight marker:content-none md:text-base [&::-webkit-details-marker]:hidden">
              <span class="flex items-center justify-between gap-4">
                {item.question}
                <span class="shrink-0 text-muted-foreground transition-transform group-open:rotate-45">
                  +
                </span>
              </span>
            </summary>
            <p class="mt-3 pb-1 text-sm leading-relaxed text-muted-foreground">{item.answer}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>