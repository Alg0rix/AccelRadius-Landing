---
import { featuresContent, type FeatureAccent } from "../../lib/features-content"

interface Props {
  /** Use paragraph styling for list titles (avoids duplicate H3s when detail cards follow). */
  listTitlesAsText?: boolean
  /** Link to standalone feature pages instead of in-page anchors. */
  linkToPages?: boolean
}

const { listTitlesAsText = false, linkToPages = false } = Astro.props

const accentDot: Record<FeatureAccent, string> = {
  blue: "bg-brand-blue",
  red: "bg-brand-red",
  dark: "bg-foreground",
  neutral: "bg-muted-foreground/50",
}
---

<section id="fitur" class="scroll-mt-20 border-b border-border py-16 md:py-24">
  <div class="mx-auto max-w-7xl px-6">
    <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.15fr)] lg:items-start lg:gap-16">
      <div data-animate="reveal-left" class="lg:sticky lg:top-24">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-red">9 modul utama</p>
        <h2 class="mt-3 text-3xl font-bold leading-[1.05] tracking-tight md:text-4xl lg:text-5xl">
          Modul platform billing ISP terintegrasi
        </h2>
        <p class="mt-4 text-base leading-relaxed text-muted-foreground">
          Sembilan modul operasional ISP — dari manajemen pelanggan dan tagihan hingga
          billing RADIUS MikroTik. Setiap modul punya halaman detail tersendiri.
        </p>

        <div
          data-animate="scale"
          data-animate-delay="0.15"
          class="mt-8 hidden rounded-2xl border border-border bg-muted/30 p-6 lg:block"
        >
          <p class="text-[10px] font-bold uppercase tracking-[0.18em] text-muted-foreground">
            Cakupan platform
          </p>
          <ul class="mt-4 space-y-3 text-sm text-foreground/80">
            <li class="flex items-center gap-2">
              <span class="size-1.5 rounded-full bg-brand-red"></span>
              Billing & pembayaran
            </li>
            <li class="flex items-center gap-2">
              <span class="size-1.5 rounded-full bg-brand-blue"></span>
              Jaringan & RADIUS
            </li>
            <li class="flex items-center gap-2">
              <span class="size-1.5 rounded-full bg-foreground"></span>
              Operasi & administrasi
            </li>
          </ul>
        </div>
      </div>

      <ol class="divide-y divide-border overflow-hidden rounded-2xl border border-border bg-background shadow-sm">
        {
          featuresContent.map((feature) => (
            <li data-stagger-item>
              <a
                href={linkToPages ? `/fitur/${feature.slug}/` : `#fitur-${feature.number}`}
                class="group flex items-start gap-4 p-5 transition-colors hover:bg-muted/40 md:gap-5 md:p-6"
              >
                <div class="flex w-12 shrink-0 flex-col items-center gap-2 md:w-14">
                  <span class="text-2xl font-bold leading-none tracking-tighter text-brand-red md:text-3xl">
                    {feature.number}
                  </span>
                  <span class={`size-1.5 rounded-full ${accentDot[feature.accent]}`} />
                </div>

                <div class="min-w-0 flex-1">
                  <div class="flex items-start justify-between gap-3">
                    {
                      listTitlesAsText ? (
                        <p class="text-base font-bold tracking-tight transition-colors group-hover:text-brand-blue md:text-lg">
                          {feature.title}
                        </p>
                      ) : (
                        <h3 class="text-base font-bold tracking-tight transition-colors group-hover:text-brand-blue md:text-lg">
                          {feature.title}
                        </h3>
                      )
                    }
                    <span
                      class="mt-1 shrink-0 text-lg text-muted-foreground/30 transition-all group-hover:translate-x-1 group-hover:text-brand-blue"
                      aria-hidden="true"
                    >
                      →
                    </span>
                  </div>
                  <p class="mt-1.5 line-clamp-2 text-sm leading-relaxed text-muted-foreground">
                    {feature.description}
                  </p>
                  <p class="mt-3 text-[10px] font-semibold uppercase tracking-[0.14em] text-foreground/45">
                    {feature.tags.join(" · ")}
                  </p>
                </div>
              </a>
            </li>
          ))
        }
      </ol>
    </div>
  </div>
</section>