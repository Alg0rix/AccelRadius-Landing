---
import { systemRequirements } from "../../lib/landing-content"
---

<section id="persyaratan" class="scroll-mt-20 py-16 md:py-20">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mb-10 max-w-2xl">
      <p class="mb-2 text-sm font-semibold text-brand-red">Infrastruktur</p>
      <h2 class="text-3xl font-bold tracking-tight md:text-4xl">Persyaratan sistem</h2>
      <p class="mt-3 text-muted-foreground">
        Accel Radius dirancang untuk server Linux produksi. Pastikan lingkungan Anda
        memenuhi minimum berikut sebelum instalasi.
      </p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        systemRequirements.map((group) => (
          <div class="rounded-2xl border border-border bg-background p-5">
            <h3 class="text-sm font-bold uppercase tracking-wider">{group.title}</h3>
            <ul class="mt-4 space-y-2">
              {
                group.items.map((item) => (
                  <li class="flex items-start gap-2 text-sm text-muted-foreground">
                    <span class="mt-1.5 size-1.5 shrink-0 rounded-full bg-brand-red" />
                    {item}
                  </li>
                ))
              }
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>