---
import { pricingComparisonNote, pricingTiers } from "../../lib/landing-content"
---

<section id="harga" class="scroll-mt-20 border-y border-border bg-muted/30 py-16 md:py-20">
  <div class="mx-auto max-w-7xl px-6">
    <div data-animate="reveal" class="mb-10 max-w-2xl">
      <p class="mb-2 text-sm font-semibold text-brand-blue">Lisensi</p>
      <h2 class="text-3xl font-bold tracking-tight md:text-4xl">Pilih paket yang sesuai</h2>
      <p class="mt-3 text-muted-foreground">
        Lisensi flat per server — tanpa biaya per-pelanggan. Mulai evaluasi gratis,
        lalu pilih paket produksi sesuai skala ISP Anda.
      </p>
    </div>

    <div data-stagger class="mx-auto grid max-w-4xl gap-4 md:grid-cols-2">
      {
        pricingTiers.map((tier) => (
          <article
            data-stagger-item
            data-hover-lift
            class:list={[
              "flex h-full flex-col rounded-2xl border p-6 md:p-8",
              tier.highlighted
                ? "border-brand-blue/40 bg-background shadow-lg ring-1 ring-brand-blue/20"
                : "border-border bg-background",
            ]}
          >
            {tier.highlighted && (
              <span class="mb-4 inline-flex w-fit rounded-full bg-brand-blue/10 px-3 py-1 text-[10px] font-bold uppercase tracking-wider text-brand-blue">
                Paling populer
              </span>
            )}
            <h3 class="text-xl font-bold tracking-tight">{tier.name}</h3>
            <p class="mt-2 text-2xl font-bold">{tier.price}</p>
            {"priceNote" in tier && tier.priceNote && (
              <p class="mt-1 text-sm font-medium text-muted-foreground">{tier.priceNote}</p>
            )}
            {"annualPrice" in tier && tier.annualPrice && (
              <p class="mt-1 text-xs text-brand-blue">{tier.annualPrice}</p>
            )}
            {"pricingDisclaimer" in tier && tier.pricingDisclaimer && (
              <p class="mt-1 text-xs text-muted-foreground">{tier.pricingDisclaimer}</p>
            )}
            <p class="mt-2 text-sm text-muted-foreground">{tier.description}</p>
            <ul class="mt-6 flex-1 space-y-2.5">
              {
                tier.features.map((feature) => (
                  <li class="flex items-start gap-2 text-sm">
                    <span class="mt-0.5 text-brand-blue">✓</span>
                    {feature}
                  </li>
                ))
              }
            </ul>
            <a
              href={tier.ctaHref}
              class:list={[
                "mt-8 inline-flex w-full items-center justify-center rounded-full px-6 py-3 text-sm font-semibold transition-all",
                tier.highlighted ? "modern-btn-primary" : "modern-btn-ghost",
              ]}
            >
              {tier.cta}
            </a>
          </article>
        ))
      }
    </div>

    <p data-animate="reveal" class="mt-8 max-w-3xl text-sm text-muted-foreground">
      {pricingComparisonNote}
    </p>
  </div>
</section>