---
import { BRAND_ICON, BRAND_NAME, BRAND_TAGLINE } from "../../lib/brand"
import { mainNav } from "../../lib/nav"
---

<header class="sticky top-0 z-50 border-b border-border/60 bg-background/80 backdrop-blur-xl">
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-6 py-3">
    <a href="/" class="flex items-center gap-2.5">
      <img src={BRAND_ICON} alt={BRAND_NAME} class="size-8 object-contain" />
      <div class="hidden sm:block">
        <p class="text-[10px] font-semibold text-brand-red">{BRAND_TAGLINE}</p>
        <p class="text-sm font-bold tracking-tight">{BRAND_NAME}</p>
      </div>
    </a>
    <nav class="flex items-center gap-0.5 sm:gap-1">
      {
        mainNav.map((item) => (
          <a
            href={item.href}
            class="rounded-full px-2.5 py-2 text-[11px] font-medium text-muted-foreground transition-colors hover:bg-muted hover:text-foreground sm:px-3 sm:text-sm"
          >
            {item.label}
          </a>
        ))
      }
      <a
        href="#install"
        class="modern-btn-primary ml-1 hidden px-4 py-2 text-xs sm:ml-2 sm:inline-flex sm:px-5 sm:py-2.5 sm:text-sm"
      >
        Mulai
      </a>
    </nav>
  </div>
</header>