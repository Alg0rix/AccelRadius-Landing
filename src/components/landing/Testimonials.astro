---
import { testimonials } from "../../lib/landing-content"
---

<section id="testimoni" class="scroll-mt-20 py-16 md:py-20">
  <div class="mx-auto max-w-7xl px-6">
    <div data-animate="reveal" class="mb-10 max-w-2xl">
      <p class="mb-2 text-sm font-semibold text-brand-red">Di lapangan</p>
      <h2 class="text-3xl font-bold tracking-tight md:text-4xl">
        Dipakai operator di seluruh Indonesia
      </h2>
      <p class="mt-3 text-muted-foreground">
        Tim ISP yang beralih ke sistem terpadu melaporkan operasi lebih rapi dan
        komunikasi antar divisi lebih cepat.
      </p>
    </div>

    <div data-stagger class="grid gap-4 md:grid-cols-3">
      {
        testimonials.map((item) => (
          <figure
            data-stagger-item
            data-hover-lift
            class="flex h-full flex-col rounded-2xl border border-border bg-background p-6"
          >
            <blockquote class="flex-1 text-sm leading-relaxed text-foreground/90">
              “{item.quote}”
            </blockquote>
            <figcaption class="mt-5 border-t border-border pt-4">
              <p class="text-sm font-semibold">{item.role}</p>
              <p class="text-xs text-muted-foreground">
                {item.region} · {item.scale}
              </p>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>