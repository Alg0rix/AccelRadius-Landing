---
import { howItWorksSteps } from "../../lib/landing-content"
---

<section id="cara-kerja" class="scroll-mt-20 border-b border-border py-16 md:py-20">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mb-10 max-w-2xl">
      <p class="mb-2 text-sm font-semibold text-brand-blue">Alur singkat</p>
      <h2 class="text-3xl font-bold tracking-tight md:text-4xl">Cara kerja Accel Radius</h2>
      <p class="mt-3 text-muted-foreground">
        Dari instalasi hingga operasional harian — tiga langkah untuk ISP yang ingin
        bergerak dari spreadsheet ke sistem terpadu.
      </p>
    </div>

    <ol class="grid gap-4 md:grid-cols-3">
      {
        howItWorksSteps.map((item) => (
          <li class="relative rounded-2xl border border-border bg-background p-6">
            <span class="mb-4 inline-flex size-10 items-center justify-center rounded-lg bg-foreground text-sm font-bold text-background">
              {item.step}
            </span>
            <h3 class="text-lg font-bold tracking-tight">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{item.description}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>