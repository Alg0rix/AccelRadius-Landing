---
import BrandIcon from "./BrandIcon.astro"
import {
  BRAND_FULL,
  BRAND_NAME,
  RELEASE_REPO,
  RELEASES_URL,
  SITE_DESCRIPTION,
} from "../../lib/brand"
import { footerNav, resourceLinks } from "../../lib/nav"

const year = new Date().getFullYear()

const resources = [
  ...resourceLinks.map((link) => ({ ...link, external: false })),
  { href: RELEASES_URL, label: "Rilis", external: true },
]

const legal = [
  { href: "/privacy", label: "Kebijakan Privasi" },
  { href: "/terms", label: "Syarat Penggunaan" },
]
---

<footer class="border-t border-border bg-foreground text-background">
  <div class="mx-auto max-w-7xl px-6 py-14">
    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-4">
      <div class="flex items-start gap-4 lg:col-span-1">
        <BrandIcon
          class="size-10 object-contain brightness-0 invert"
          width={40}
          height={40}
          sizes="40px"
        />
        <div>
          <p class="font-bold tracking-tight">{BRAND_FULL}</p>
          <p class="mt-1 text-sm text-background/50">{SITE_DESCRIPTION}</p>
        </div>
      </div>

      <div>
        <p class="mb-3 text-xs font-semibold uppercase tracking-wider text-background/40">
          Navigasi
        </p>
        <ul class="space-y-2">
          {
            footerNav.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-background/70 transition-colors hover:text-background"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <p class="mb-3 text-xs font-semibold uppercase tracking-wider text-background/40">
          Resources
        </p>
        <ul class="space-y-2">
          {
            resources.map((link) => (
              <li>
                <a
                  href={link.href}
                  target={link.external ? "_blank" : undefined}
                  rel={link.external ? "noopener noreferrer" : undefined}
                  class="text-sm text-background/70 transition-colors hover:text-background"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
          <li>
            <a
              href={RELEASE_REPO}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-background/70 transition-colors hover:text-background"
            >
              GitHub
            </a>
          </li>
        </ul>
      </div>

      <div>
        <p class="mb-3 text-xs font-semibold uppercase tracking-wider text-background/40">
          Legal
        </p>
        <ul class="space-y-2">
          {
            legal.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-background/70 transition-colors hover:text-background"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
        <p class="mt-4 text-xs text-background/30">© {year} Accel Radius</p>
      </div>
    </div>
  </div>
</footer>