---
import Layout from "../layouts/Layout.astro"
import Header from "../components/landing/Header.astro"
import Hero from "../components/landing/Hero"
import HowItWorks from "../components/landing/HowItWorks.astro"
import Compare from "../components/landing/Compare.astro"
import FeatureList from "../components/landing/FeatureList.astro"
import Integrations from "../components/landing/Integrations.astro"
import Stats from "../components/landing/Stats"
import Testimonials from "../components/landing/Testimonials.astro"
import Pricing from "../components/landing/Pricing.astro"
import WhySelfHost from "../components/landing/WhySelfHost.astro"
import Requirements from "../components/landing/Requirements.astro"
import Install from "../components/landing/Install"
import Resources from "../components/landing/Resources.astro"
import Faq from "../components/landing/Faq.astro"
import Cta from "../components/landing/Cta"
import Footer from "../components/landing/Footer.astro"
import LandingMotion from "../components/LandingMotion"
import AssistantChat from "../components/landing/AssistantChat"
import SeoIntro from "../components/landing/SeoIntro.astro"
import { DEFAULT_TITLE } from "../lib/seo"
import {
  faqPageSchema,
  productSchema,
  reviewSchema,
} from "../lib/schema"
---

<Layout
  title={DEFAULT_TITLE}
  jsonLd={[faqPageSchema(), productSchema(), reviewSchema()]}
>
  <Header />
  <LandingMotion client:load />
  <main>
    <Hero client:only="react" />
    <SeoIntro />
    <HowItWorks />
    <Compare />
    <FeatureList linkToPages />
    <Integrations />
    <Stats client:only="react" />
    <Testimonials />
    <Pricing />
    <WhySelfHost />
    <Requirements />
    <Install client:visible />
    <Resources />
    <Faq />
    <Cta client:visible />
  </main>
  <Footer />
  <AssistantChat client:load />
</Layout>