---
import Layout from "../../layouts/Layout.astro"
import Header from "../../components/landing/Header.astro"
import Footer from "../../components/landing/Footer.astro"
import PageHeader from "../../components/landing/PageHeader.astro"
import { BRAND_FULL } from "../../lib/brand"
import { blogPosts } from "../../lib/blog-posts"

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString("id-ID", {
    day: "numeric",
    month: "long",
    year: "numeric",
  })
}
---

<Layout
  title={`Blog — ${BRAND_FULL}`}
  description="Panduan operasional ISP: billing, RADIUS MikroTik, mengurangi tunggakan, migrasi data, dan perbandingan self-hosted vs SaaS."
  canonicalPath="/blog"
>
  <Header />
  <main>
    <PageHeader
      eyebrow="Panduan ISP"
      title="Blog operasional & billing ISP"
      description="Artikel praktis untuk operator internet di Indonesia — ditulis untuk masalah nyata: tagihan, jaringan, koleksi, dan migrasi sistem."
    />

    <section class="py-16 md:py-20">
      <div class="mx-auto max-w-3xl px-6">
        <ul class="space-y-6">
          {
            blogPosts.map((post) => (
              <li>
                <article class="rounded-2xl border border-border bg-background p-6 transition-shadow hover:shadow-md">
                  <div class="flex flex-wrap items-center gap-3 text-xs text-muted-foreground">
                    <time datetime={post.publishedAt}>{formatDate(post.publishedAt)}</time>
                    <span aria-hidden>·</span>
                    <span>{post.readTime}</span>
                  </div>
                  <h2 class="mt-3 text-xl font-bold tracking-tight">
                    <a
                      href={`/blog/${post.slug}`}
                      class="transition-colors hover:text-brand-blue"
                    >
                      {post.title}
                    </a>
                  </h2>
                  <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
                    {post.description}
                  </p>
                  <a
                    href={`/blog/${post.slug}`}
                    class="mt-4 inline-flex text-sm font-semibold text-brand-blue hover:underline"
                  >
                    Baca selengkapnya →
                  </a>
                </article>
              </li>
            ))
          }
        </ul>
      </div>
    </section>
  </main>
  <Footer />
</Layout>